PORT=4000
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SUPABASE-SERVICE-ROLE-KEY]
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=sk_test_xxxxxxxxxxxxxxxxx
APP_BASE_URL=https://nextgenforgebackend.onrender.com
EMAIL_ONBOARDING_URL=https://agenticaibuilders.slack.com/
EMAIL_FROM=hello@nextgenforge.com
EMAIL_FROM_NAME=NextGenForge
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password


curl -i -X POST "https://nextgenforgebackend.onrender.com/api/payments/webhook" \
  -H "Content-Type: application/json" \
  -H "x-paystack-signature: (printf '%s' "$PAYLOAD" | openssl dgst -sha512 -hmac "sk_test_xxxxxxxxxxxxxxxxxT" -hex | sed 's/^.* //')" \
  -d "{"event":"charge.success","data":{"reference":"nfg_transfer_test_123","status":"success","amount":10000,"currency":"NGN","customer":{"email":"john@example.com"},"authorization":{"receiver_bank_account_number":"1234567890"}}}"